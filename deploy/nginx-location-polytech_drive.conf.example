# Фрагмент для server { } на aspc.kz — прокси на gunicorn.
# ^~ — чтобы не перехватывало SPA/статикой с location / и try_files.
# Добавьте в тот же server { }, что и listen 443 ssl (HTTPS).
# backend: gunicorn на 127.0.0.1:8010

location ^~ /polytech_drive/ {
    proxy_pass http://127.0.0.1:8010;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 300s;
    client_max_body_size 50m;
}

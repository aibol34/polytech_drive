# Flask

SECRET_KEY=change-me-to-a-long-random-string

# Срок cookie «Запомнить меня» на странице входа (дни). По умолчанию 365.
# REMEMBER_COOKIE_DAYS=365

FLASK_ENV=development

# --- Деплой за nginx на подпути (например https://aspc.kz/polytech_drive) ---
# Префикс URL без завершающего слэша. Пусто = приложение в корне домена.
# APPLICATION_ROOT=/polytech_drive
# Публичный URL с https и подпутём — для og:meta, API и абсолютных ссылок на медиа.
# PUBLIC_BASE_URL=https://aspc.kz/polytech_drive
# После включения HTTPS на nginx: USE_HTTPS=true (или оставьте только PUBLIC_BASE_URL с https://).
# USE_HTTPS=true

# HTTPS на сервере: bash deploy/enable-https.sh — перед запуском: export CERTBOT_EMAIL=ваш@email
# Поддомен только под Flask (без /polytech_drive): APPLICATION_ROOT пусто, PUBLIC_BASE_URL=https://drive.aspc.kz — см. deploy/subdomain-drive.example.conf

# Публичный CORS: * = любой сайт может дергать API /g /media (fetch). Список доменов: https://a.kz,https://b.kz
# CORS_ORIGINS=*

# SQLite (default: instance/polytech_drive.db)

# DATABASE_URL=sqlite:///E:/ansara/polytech_drive/instance/polytech_drive.db



# --- Google Drive (choose ONE primary method) ---



# A) API key (simplest). In Cloud Console restrict key to "Google Drive API".

# Folders must be shared: "Anyone with the link" → Viewer (public read).

GOOGLE_DRIVE_API_KEY=paste-your-google-api-key-here



# B) Service account JSON (private folders: share folder with SA email from JSON).

# GOOGLE_SERVICE_ACCOUNT_JSON=E:/path/to/service-account.json

# GOOGLE_APPLICATION_CREDENTIALS=E:/path/to/service-account.json



# If both A and B are set, the JSON file wins when the path exists.

# Таймаут HTTP к Google (сек). При SSL handshake timeout попробуйте 180 или 300.
# GOOGLE_HTTP_TIMEOUT=120



# Gallery tuning

PHOTOS_PER_PAGE=24

# Максимум фото в одном альбоме (импорт из Drive + ZIP «скачать всё»).
# MAX_PHOTOS_PER_ALBUM=5000

ZIP_MAX_FILES=5000

MEDIA_CACHE_SECONDS=86400


